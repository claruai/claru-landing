# =============================================================================
# Claru Landing — Environment Variables
# Copy to .env.local and fill in real values
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (Vercel, local dev)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Admin auth (Vercel, local dev)
# ---------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=

# ---------------------------------------------------------------------------
# AI / LLM keys (Vercel, local dev, enrichment scripts)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=          # text-embedding-3-small for catalog embeddings
GEMINI_API_KEY=          # gemini-2.0-flash for vision enrichment
ANTHROPIC_API_KEY=       # prospect research & other agent tasks

# ---------------------------------------------------------------------------
# MCP server auth (Vercel)
# ---------------------------------------------------------------------------
ADMIN_MCP_TOKEN=         # bearer token for /api/mcp endpoint

# ---------------------------------------------------------------------------
# AWS S3 (Vercel, local dev, enrichment scripts)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=moonvalley-annotation-platform

# ---------------------------------------------------------------------------
# CloudFront signed URLs (Vercel, local dev)
# ---------------------------------------------------------------------------
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=  # PEM private key (use quotes for multiline)

# ---------------------------------------------------------------------------
# Resend email (Vercel)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------------------------------------------------------------------------
# PostHog analytics (Vercel, local dev)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY= # PostHog project API key (phc_...)

# ---------------------------------------------------------------------------
# Outbound / Enrichment APIs (local dev, scripts)
# ---------------------------------------------------------------------------
HUNTER_API_KEY=          # hunter.io — email discovery + verification
PDL_API_KEY=             # peopledatalabs.com — person enrichment + email verification

# ---------------------------------------------------------------------------
# Cron (Vercel)
# ---------------------------------------------------------------------------
CRON_SECRET=             # validates Vercel cron invocations

# ---------------------------------------------------------------------------
# Admin CRM (Vercel, local dev)
# ---------------------------------------------------------------------------
# Admin email allowlist — server-only, do NOT use NEXT_PUBLIC_ prefix
ADMIN_EMAILS=john@claru.ai,john@moonvalley.com,chad@claru.ai
SMARTLEAD_API_KEY=       # Smartlead API key for campaign sync and lead queuing

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.!*!._*
.mcp.json

# claude code local settings and skills
.claude/settings.local.json
.claude/skills/

# playwright screenshots
.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.github/workflows/

# Playwright
.playwright-mcp/
playwright-report/
test-results/

# Brand kit zip
brand-kit.zip

# Large screenshot artifacts
*.png
!public/**/*.png
!src/**/*.png
!brand-kit/**/*.png

# Video originals (keep web-optimized only)
*.mov
brand-kit/
slide-deck-backgrounds/

# Enrichment assets — only keep files referenced by V2 page
public/enrichment-assets/*
!public/enrichment-assets/depth-video/90b2c5b4_depth_only.mp4
!public/enrichment-assets/pose-video/9d73d711_pose_web.mp4
!public/enrichment-assets/segmentation/12b46dac_seg_overlay.mp4

# HMR2 showcase — keep only final outputs
public/images/hmr2-showcase/

# Large asset dirs not used in V2
public/remotion-assets/
public/videos/enrichment-viz/

# Temp/working files
tmp/
scripts/fal-wham/.venv*/
scripts/fal-hawor/
